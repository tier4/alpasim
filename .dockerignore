# Use allowlist approach - ignore everything by default
*

# Only include what's needed for the runtime
!src/
!src/grpc/
!src/runtime/**
!src/grpc/**
!src/utils/**
!src/utils_rs/**
!src/ddb/**
!src/eval/**
!src/physics/**
!src/controller/**
!src/tools/**
!src/plugins/**
!src/driver/**
!src/wizard/**
!src/trafficsim/**
!plugins/internal/**
!plugins/transfuser_driver/**
!e2e_challenge/
!e2e_challenge/starter_kit/
!e2e_challenge/starter_kit/**
!pyproject.toml

# Exclude specific runtime directories/files we don't need
src/runtime/build.env
src/runtime/test_output
**/.venv
**/*.egg-info
**/__pycache__
**/.pytest_cache
**/dist
**/build
**/.mypy_cache
**/runs
**/outputs
