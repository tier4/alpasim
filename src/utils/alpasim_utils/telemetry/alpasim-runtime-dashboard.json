    {
      "type": "histogram",
      "title": "Process CPU saturation histogram",
      "gridPos": {
        "x": 6,
        "y": 17,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:process_cpu_utilization_percent:max_by_group:rate30s{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "max {{groupname}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:process_cpu_utilization_percent:per_process:rate30s{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"} and on (run_uuid, run_name, groupname, pid, port, instance) topk by (groupname) (3, max_over_time(alpasim:process_cpu_utilization_percent:per_process:rate30s{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}[$__range] @ end()))",
          "legendFormat": "top {{groupname}} {{port}} pid={{pid}}",
