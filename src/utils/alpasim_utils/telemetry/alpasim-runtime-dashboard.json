{
  "title": "AlpaSim Runtime",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "run_uuid",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(up{job=\"alpasim-runtime-worker\"}, run_uuid)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "run_name",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(up{run_uuid=~\"$run_uuid\"}, run_name)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "type": "query",
        "name": "worker_id",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(alpasim_rpc_duration_seconds_count{run_uuid=~\"$run_uuid\"}, worker_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "service",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(alpasim_rpc_duration_seconds_count{run_uuid=~\"$run_uuid\"}, service)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "method",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(alpasim_rpc_duration_seconds_count{run_uuid=~\"$run_uuid\",service=~\"$service\"}, method)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "tag",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(alpasim_rpc_duration_seconds_count{run_uuid=~\"$run_uuid\"}, tag)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "node",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(up{run_uuid=~\"$run_uuid\"}, node)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "groupname",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(namedprocess_namegroup_cpu_seconds_total{run_uuid=~\"$run_uuid\"}, groupname)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "type": "query",
        "name": "gpu",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL{run_uuid=~\"$run_uuid\"}, gpu)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Metrics plot summary",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "RPC duration p95",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:rpc_duration_seconds:p95{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "p95 {{method}}"
        }
      ]
    },
    {
      "type": "histogram",
      "title": "RPC duration histogram",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "(alpasim:rpc_duration_seconds:p95{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}) > 0",
          "legendFormat": "p95 {{method}}"
        }
      ],
      "options": {
        "bucketCount": 30,
        "bucketSize": 0.05,
        "combine": false,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "RPC blocking p95",
      "gridPos": {
        "x": 6,
        "y": 33,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:rpc_blocking_seconds:p95{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "p95 {{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPC request rate",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum by (method) (rate(alpasim_rpc_duration_seconds_count{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\",worker_id=~\"$worker_id\",method=~\"$method\",tag=~\"$tag\"}[1m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPC queue depth latest",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:rpc_queue_depth_at_start_latest:max{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "{{service}} max",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:rpc_queue_depth_at_start_latest:min{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "{{service}} min",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "avg_over_time(alpasim:rpc_queue_depth_at_start_latest:max{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}[10m])",
          "legendFormat": "{{service}} max 10m avg",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "avg_over_time(alpasim:rpc_queue_depth_at_start_latest:min{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}[10m])",
          "legendFormat": "{{service}} min 10m avg",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^controller max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^controller min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^driver max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^driver min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^sensorsim max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^sensorsim min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^physics max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^physics min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-purple",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^traffic max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^traffic min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^video_model max.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^video_model min.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* (max|min)$"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    10
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "custom.showPoints",
                "value": "never"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* 10m avg$"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.showPoints",
                "value": "never"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "histogram",
      "title": "RPC queue depth histogram",
      "gridPos": {
        "x": 6,
