      "title": "Step duration p95",
      "gridPos": {
        "x": 18,
        "y": 9,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "alpasim:step_duration_seconds:p95{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}",
          "legendFormat": "p95"
        }
      ]
    },
    {
