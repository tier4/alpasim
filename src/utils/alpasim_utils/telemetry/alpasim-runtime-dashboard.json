        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "avg_over_time(alpasim:process_cpu_utilization_percent:max_by_group:rate30s{run_uuid=~\"$run_uuid\",run_name=~\"$run_name\"}[10m])",
          "legendFormat": "10m avg {{groupname}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*controller.*"
            },
            "properties": [
              {
                "id": "color",
